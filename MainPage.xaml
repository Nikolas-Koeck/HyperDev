<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HyperDev"
    x:Class="HyperDev.MainPage">

    <ContentPage.BindingContext>
        <local:MainViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="20" Spacing="20">

        <!-- SOURCE GRID -->
        <Label Text="Drag Features" FontAttributes="Bold"/>

        <CollectionView ItemsSource="{Binding Features}" ItemsLayout="VerticalGrid, 2">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" BorderColor="Gray">

                        <Label Text="{Binding Name}">
                            <Label.GestureRecognizers>
                                <DragGestureRecognizer DragStarting="OnDragStarting"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- TARGET GRID -->
        <Label Text="Drop into Slots" FontAttributes="Bold"/>

        <CollectionView ItemsSource="{Binding Slots}" ItemsLayout="VerticalGrid, 2">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" BorderColor="Black">

                        <VerticalStackLayout>

                            <Label Text="{Binding Title}" />

                            <Label Text="{Binding AssignedFeature.Name}"
                                   TextColor="Blue"
                                   FontAttributes="Bold"/>

                            <!-- Drop zone -->
                            <Frame BackgroundColor="#EEE" HeightRequest="50">
                                <Frame.GestureRecognizers>
                                    <DropGestureRecognizer
                                        AllowDrop="True"
                                        Drop="OnDrop"
                                        DragOver="DropGestureRecognizer_DragOver"/>
                                </Frame.GestureRecognizers>
                            </Frame>

                            <Switch IsToggled="{Binding IsLocked}" />

                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>